generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===========USER AUTHENTICATION AND AUTHORIZATION MODEL/ ROLE BASED ACCESS CONTROL ===========

enum AuthRole {
  SUPER_ADMIN
  ADMIN
  USER
}

model StaffRole {
  id        String   @id @default(uuid())
  code      String   @unique // MD, PM, SE
  name      String
  createdAt DateTime @default(now())

  staffProfile StaffProfile[]

  @@index([name])
}

model State {
  id   String @id @default(uuid())
  code String @unique // ABJ, LAG
  name String

  staffProfiles StaffProfile[]

  @@index([name])
}

model StaffProfile {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  staffId String @unique // STC-PM-ABJ-00012

  roleId String
  role   StaffRole @relation(fields: [roleId], references: [id])

  stateId String
  state   State  @relation(fields: [stateId], references: [id])

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([staffId])
  @@index([roleId])
  @@index([stateId])
}

model StaffIdSequence {
  id        String @id @default(uuid())
  company   String // STC
  roleCode  String // PM
  stateCode String // ABJ
  lastValue Int    @default(0)

  @@unique([company, roleCode, stateCode])
}

model User {
  id                 String  @id @default(uuid())
  email              String  @unique
  fullName           String
  phoneNumber        String?
  password           String
  isActive           Boolean @default(true)
  mustChangePassword Boolean @default(true)

  notifications        Notification[]
  role                 AuthRole         @default(USER)
  refreshSessions      RefreshSession[]
  staffProfiles        StaffProfile?
  // === Reverse relations ===
  fundRequestsCreated  FundRequest[]    @relation("FundRequestRequestedBy")
  fundRequestsApproved FundRequest[]    @relation("FundRequestApprovedBy")
  fundRequestsRejected FundRequest[]    @relation("FundRequestRejectedBy")
  fundRequestHistory   FundRequestHistory[]
  passwordResetTokens PasswordResetToken[]


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fullName])
  @@index([email])
  @@index([role])
}

model RefreshSession {
  id           String    @id @default(uuid())
  userId       String
  refreshToken String // hashed refresh token
  deviceId     String
  userAgent    String
  ipAddress    String
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([deviceId, expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique // This will store the hashed token
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Cascade delete ensures tokens are removed if a user is deleted
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@unique([userId])
}


// ============================== PO Management Schema =============================
model PurchaseOrder {
  id   String @id @default(uuid())
  duid String

  projectName String?
  projectCode String?

  prNumber String?
  poNumber String?

  poLines PurchaseOrderLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([duid, poNumber])
  @@index([duid])
  @@index([poNumber])
  @@index([projectName])
  @@index([projectCode])
}

enum PoAgingFlag {
  GREEN
  WARNING
  RED
}

model PurchaseOrderLine {
  id              String @id @default(uuid())
  purchaseOrderId String

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  poLineNumber String?
  pm           String?
  pmId         String? 

  itemCode        String?
  itemDescription String?

  poTypeId String?
  poType   PoType? @relation(fields: [poTypeId], references: [id])

  unitPrice         Decimal?  @db.Decimal(15, 2)
  requestedQuantity Int?
  poLineAmount      Decimal?  @db.Decimal(15, 2)
  poIssuedDate      DateTime?

  poInvoiceDate   DateTime?
  allowedOpenDays Int?

  //=======FINANCIAL CONTROL
  contractAmount      Decimal? @db.Decimal(15, 2)
  totalRequestedAmount Decimal @default(0) @db.Decimal(15, 2)
  totalRejectedAmount Decimal  @default(0) @db.Decimal(15, 2)
  totalApprovedAmount Decimal  @default(0) @db.Decimal(15, 2)
  remainingBalance    Decimal  @default(0) @db.Decimal(15, 2)

  poLineStatus PoLineStatus @default(NOT_INVOICED)

  agingFlag             PoAgingFlag  @default(GREEN)
  lastAgingNotifiedFlag PoAgingFlag?

  FundRequests       FundRequest[]
  ContractAmendments ContractAmendment[]
  version             Int      @default(0) // contract amendment tracking to prevent data corruption when two people try to edit the same thing at the exact same time 
  fundRequestHistory FundRequestHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([purchaseOrderId, poLineNumber])
  @@index([purchaseOrderId])
  @@index([poLineNumber])
  @@index([itemCode])
  @@index([unitPrice])
  @@index([requestedQuantity])
  @@index([poLineAmount])
  @@index([poTypeId])
  @@index([poLineStatus])
  @@index([pm])
  @@index([pmId])
  @@index([poIssuedDate])
  @@index([poLineStatus, allowedOpenDays])
}

//==PO LINE LIFE CYCLE STATUS===
enum PoLineStatus {
  NOT_INVOICED
  INVOICED
}

model PoType {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  description String?

  purchaseOrders PurchaseOrderLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name, code])
}

// ================PURCHASE ORDER IMPORT HISTORY
model PoImportHistory {
  id          String @id @default(uuid())
  fileName    String
    fileHash    String   @unique 

  duidCount   Int
  poCount     Int
  poLineCount Int
  status      String // e.g. "SUCCESS", "PARTIAL", "FAILED"
  errors      Json? // JSON string or text for errors

  createdBy String? // optional userId
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

// ============ FUND REQUESTS ============

model FundRequest {
  id                  String @id @default(uuid())
  purchaseOrderLineId String

  purchaseOrderLine PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id], onDelete: Cascade)

  requestedAmount Decimal @db.Decimal(15, 2)

  // Intent / reason for this specific fund request
  requestPurpose String
  source FundRequestSource @default(STRUCTURED)

  status FundRequestStatus @default(PENDING)

  requestedBy     String
  requestedByUser User   @relation("FundRequestRequestedBy", fields: [requestedBy], references: [id])

  approvedBy     String?
  approvedByUser User?   @relation("FundRequestApprovedBy", fields: [approvedBy], references: [id])

  rejectedBy     String?
  rejectedByUser User?    @relation("FundRequestRejectedBy", fields: [rejectedBy], references: [id])

  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())

  notifications Notification[]
  fundRequestsHistory FundRequestHistory[]

  @@index([purchaseOrderLineId])
  @@index([status])
  @@index([requestedBy])
  @@index([status, createdAt(sort: Desc)])
  @@index([requestedBy, createdAt(sort: Desc)])

}

model FundRequestHistory {
  id                  String         @id @default(cuid())
  fundRequestId       String
  purchaseOrderLineId String
  requestedBy         String
  requestedAmount     Decimal
  requestPurpose      String
  status              FundRequestStatus
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // Relations
  fundRequest         FundRequest    @relation(fields: [fundRequestId], references: [id], onDelete: Cascade)
  purchaseOrderLine   PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id], onDelete: Cascade)
  user                User           @relation(fields: [requestedBy], references: [id], onDelete: Cascade)

  @@index([fundRequestId])
  @@index([purchaseOrderLineId])
  @@index([requestedBy])
}


enum FundRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FundRequestSource {
  STRUCTURED
  MANUAL
}


// ============ CONTRACT AMENDMENTS (AUDIT) ============

model ContractAmendment {
  id                  String @id @default(uuid())
  purchaseOrderLineId String

  purchaseOrderLine PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id], onDelete: Cascade)

  oldAmount Decimal @db.Decimal(15, 2)
  newAmount Decimal @db.Decimal(15, 2)

  reason     String
  approvedBy String

  createdAt DateTime @default(now())

  @@index([purchaseOrderLineId])
}

// ============ NOTIFICATIONS ============

model Notification {
  id     String @id @default(uuid())
  userId String

  user User @relation(fields: [userId], references: [id])

  fundRequestId String?
  fundRequest   FundRequest? @relation(fields: [fundRequestId], references: [id], onDelete: Cascade)

  type    NotificationType
  payload Json

  sentAt    DateTime?
  createdAt DateTime  @default(now())
  readAt DateTime?

  @@index([fundRequestId])
  @@index([sentAt])
  @@index([readAt])
  @@index([createdAt])
  @@index([userId])
  @@index([type])
}

enum NotificationType {
  FUND_REQUEST_CREATED
  FUND_REQUEST_APPROVED
  FUND_REQUEST_REJECTED
  CONTRACT_AMENDED
  PO_AGING_WARNING
  ACCOUNT_CREATED
  PASSWORD_RESET
  PASSWORD_CHANGED
  PO_AGING_ALERT    
}

model FailedNotification {
  id             String           @id @default(cuid())
  notificationId String
  userId         String
  type           NotificationType
  payload        Json
  error          String
  createdAt      DateTime         @default(now())
}
