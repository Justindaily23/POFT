generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
}

// ===========USER AUTHENTICATION AND AUTHORIZATION MODEL/ ROLE BASED ACCESS CONTROL ===========

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}
model User {
  id String @id @default(uuid())
  email String @unique
  fullName String
  phoneNumber String?
  password String
  isActive Boolean @default(true)
  mustChangePassword Boolean @default(true)


  role Role @default(USER)
  refreshSessions RefreshSession[]
  // === Reverse relations ===
  fundRequestsCreated  FundRequest[] @relation("FundRequestRequestedBy")
  fundRequestsApproved FundRequest[] @relation("FundRequestApprovedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fullName])
  @@index([email])
}

model RefreshSession {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   // hashed refresh token
  deviceId     String
  userAgent    String
  ipAddress    String
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([expiresAt])
}




